# App
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/arris

# Cloud Provider: aws | azure
CLOUD_PROVIDER=aws

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=arris-storage
AWS_SQS_IMPORT_QUEUE_URL=
AWS_SQS_EXPORT_QUEUE_URL=
AWS_SQS_NOTIFICATION_QUEUE_URL=
AWS_SES_FROM_EMAIL=noreply@arris.ai
AWS_SNS_REGION=us-east-1

# Azure
AZURE_BLOB_CONN_STR=
AZURE_BLOB_CONTAINER=arris-storage
AZURE_SERVICEBUS_CONN_STR=
AZURE_COMM_SERVICES_CONN_STR=
AZURE_KEYVAULT_URL=

# Payment Gateway: razorpay | cashfree
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
